# LLM — Ollama (free local) or Mistral API
# Set LLM_PROVIDER=ollama for long runs (no rate limits on M4)
LLM_PROVIDER=auto
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://localhost:11434

# Vision fallback for code OCR (ollama pull moondream)
VLM_MODEL=moondream
USE_VLM_FALLBACK=true

# Transcription
WHISPER_MODEL=small
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v2.5

# Video frame sampling
FRAME_INTERVAL_SECONDS=45
FRAME_DIFF_THRESHOLD=0.02

# Course planner (activates for transcripts longer than this many chars)
COURSE_PLANNER_THRESHOLD=12000

# Domain filter
MIN_CS_KEYWORD_HITS=3

# Embeddings for RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Primary reference (canonical notes format + content)
PRIMARY_REFERENCE=fastapi_tutorial
PRIMARY_REFERENCE_PDF=style_samples/fastapi_tutorial.pdf
PRIMARY_REF_K=3
